        @Data
        @NoArgsConstructor
        @AllArgsConstructor
        public class Product{
            private int prodId;
            private String name;
            private int price;
        }

        @Service 
        public class ProductService{
            //Dummy Data
            // List<Product> products = new ArrayList<>();
            // CopyOnWriteArrayList makes your in-memory dummy data safely thread-safe for concurrent users
            private final List<Product> products = new CopyOnWriteArrayList<>();

            public ProductService(){
                products.add(new Product(1, "Hide&Seek", 30));
                products.add(new Product(2, "Cube", 120));
                products.add(new Product(3, "bottle", 340));
            }

            public List<Product> getAllProd(){
                System.out.println("List of products: "+products);
                return products;
            }

            public Product getProdById(int prodId){
                return products.stream()
                        .filter(p -> p.getProdId() == prodId) // p.getProdId() in Product we use setter and getter in form of @Data
                        .peek(p -> System.out.println("Product Found: "+p))
                        .findFirst()
                        .orElseThrow(() -> new ResponseStatusException(
                            HttpStatus.NOT_FOUND, "Product with ID " + prodId + " not found"
                        ));

                // Product foundProduct = products.stream()
                //         .filter(p -> p.getProdId() == prodId)
                //         .findFirst()
                //         .orElseThrow(() -> new ResponseStatusException(
                //             HttpStatus.NOT_FOUND, "Product with ID " + prodId + " not found"
                //         ));
                // System.out.println("Found product: " + foundProduct);
                // return foundProduct;

                // OR 

                // if not stream then 
                // for (Product p : products) {
                //     // 2. Check if the ID matches
                //     if (p.getProdId() == prodId) {
                //         return p; // Found it! Return it right away and stop looping
                //     }
                // }
                // 
                // throw new ResponseStatusException(
                //     HttpStatus.NOT_FOUND, "Product with ID " + prodId + " not found"
                // );
            }

            // public Product addProd(int id, String name, int price){
            //     boolean idExist = products.stream()
            //                         .anyMatch(p -> p.getProdId() == id);
            //     if(idExist) {
            //         throw new ResponseStatusException(
            //             HttpStatus.CONFLICT, "Product with ID " + id + " already exists."
            //         );
            //     }
            //     Product newProd = new Product(id, name, price);
            //     products.add(newProd);
            //     System.out.println("Successfully Added: "+newProd);
            //     return newProd;
            // }
            public Product addProd(Product newProd){
                boolean idExist = products.stream()
                                    .anyMatch(p -> p.getProdId() == newProd.getProdId());
        
                if (idExist) {
                    throw new ResponseStatusException(
                            HttpStatus.CONFLICT, "Product with ID " + newProd.getProdId() + " already exists."
                    );
                }
                products.add(newProd);
                System.out.println("Successfully Added: " + newProd);
                return newProd;
            }

            public Product updateProd(Product prod){
                Product targetProduct = products.stream()
                                            .filter(p -> p.getProdId() == prod.getProdId())
                                            .findFirst()
                                            .orElseThrow(() -> new ResponseStatusException(
                                                HttpStatus.NOT_FOUND, "Product with ID " + prod.getProdId() + " Not Found"
                                            ));
                targetProduct.setName(prod.getName());
                targetProduct.setPrice(prod.getPrice());
                System.out.println(targetProduct + "  Updated Successfully.");
                return targetProduct;
            }

            public String deleteProd(int id){
                // Product removeProduct = products.stream()
                //                             .filter(p -> p.getProdId() == id)
                //                             .findFirst()
                //                             .orElseThrow(new ResponseStatusException(
                //                                 HttpStatus.NOT_FOUND, "Product with ID "+ id +" Not Found."
                //                             ));
                // products.remove(removeProduct);
                // return removeProduct + " Deleted Successfully";

                // OR

                boolean isExist = products.stream()
                                    .anyMatch(p -> p.getProdId() == id);

                if(!isExist){
                    throw new ResponseStatusException(
                        HttpStatus.NOT_FOUND, "Product with ID "+ id +" Not Found."
                    );
                }
                products.removeIf(p -> p.getProdId() == id);
                System.out.println("Product with ID "+ id+ " Removed Successfully");
                return "Product with ID " + id + " deleted successfully.";
            }
        }
        
