Spring MVC and Layers
        @RestController
        @RequestMapping("/api")
        public class LoginController{
            @GetMapping("/login")
            public String login(){
                return "Login Page";
            }
        }

        @RestController
        @RequestMapping("/api")
        @RequiredArgsConstructor // Automatically creates the constructor for final fields (Replaces @Autowired)
        public class ProductController{

            // @Autowired
            private ProductService prodServe;

            @GetMapping("/products")
            public List<Product> getAllProduct(){
                return prodServe.getAllProd();
            }

            @GetMapping("/products/{prodId}")
            public Product getProductById(@PathVariable int prodId){
                return prodServe.getProdById(prodId);
            }

            // While this works, passing object values as query parameters (/api/products?id=4&name=mug&price=150) is a 
            // poor REST API design choice. If your product model grows to include 15 fields, your method 
            // signature will become unmanageable.
            // @PostMapping("/products")
            // public Product addProduct(@RequestParam int id, @RequestParam String name, @RequestParam int price){
            //     return prodServe.addProd(id, name, price);
            // }
            @PostMapping("/products")
            public Product addProduct(@RequestBody Product prod) {
                return prodServe.addProd(prod);
            }

            @PutMapping("/products")
            public Product updateProduct(@RequestBody Product prod){
                return prodServe.updateProd(prod);
            }

            @DeleteMapping("/products/{id}")
            public String removeProduct(@PathVariable int id){
                return prodServe.deleteProd(id);
            }
        }

        Now want to install the lombok
